# ---------------------------------------------------------------------------
# Supabase (database + per-tenant Row Level Security)
# From your Supabase project: Settings -> API
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server only — never expose to the browser

# ---------------------------------------------------------------------------
# Provider/admin allow-list. Comma-separated emails that are auto-promoted to
# the global "admin" app_role on login. Admins can create companies (tenants)
# and assign users to them. Everyone else signs up as a normal builder.
# ---------------------------------------------------------------------------
ADMIN_EMAILS=you@yourcompany.com

# ---------------------------------------------------------------------------
# AI providers for suggestions (ChatGPT / Claude / Gemini)
# These are pay-as-you-go *API* keys, NOT consumer subscriptions.
#   ChatGPT Plus  is NOT an OpenAI API key   -> https://platform.openai.com/api-keys
#   Claude Max    is NOT an Anthropic key    -> https://console.anthropic.com  (API Keys)
#   Gemini app    is NOT a Google AI key     -> https://aistudio.google.com/app/apikey
#
# Set at least ONE. AI_PROVIDER picks the default; if unset, the app uses the
# first key it finds. With no key set, suggestions disable and the role-match
# falls back to a local heuristic.
# ---------------------------------------------------------------------------
AI_PROVIDER=openai            # openai | anthropic | google

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash

# ---------------------------------------------------------------------------
# Gmail connection (OAuth) — lets an agent read a user's inbox to identify spam.
# These are DIFFERENT from GOOGLE_API_KEY above (that one is for Gemini text).
# Create at https://console.cloud.google.com → APIs & Services → Credentials →
# "OAuth client ID" (type: Web application). Enable the Gmail API. Add this exact
# redirect URI to the client:  {APP_URL}/api/connections/google/callback
# ---------------------------------------------------------------------------
APP_URL=http://localhost:3000
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# 32-byte hex secret that encrypts secrets at rest: stored OAuth tokens AND each
# company's BYO AI provider keys (Settings → AI provider keys). Rotating it makes
# previously stored keys/tokens undecryptable (they'll need to be re-entered).
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONNECTIONS_ENC_KEY=
