# ---------------------------------------------------------------------------
# Supabase (database + per-tenant Row Level Security)
# From your Supabase project: Settings -> API
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server only — never expose to the browser

# ---------------------------------------------------------------------------
# AI providers for suggestions (ChatGPT / Claude / Gemini)
# These are pay-as-you-go *API* keys, NOT consumer subscriptions.
#   ChatGPT Plus  is NOT an OpenAI API key   -> https://platform.openai.com/api-keys
#   Claude Max    is NOT an Anthropic key    -> https://console.anthropic.com  (API Keys)
#   Gemini app    is NOT a Google AI key     -> https://aistudio.google.com/app/apikey
#
# Set at least ONE. AI_PROVIDER picks the default; if unset, the app uses the
# first key it finds. With no key set, suggestions disable and the role-match
# falls back to a local heuristic.
# ---------------------------------------------------------------------------
AI_PROVIDER=openai            # openai | anthropic | google

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-latest

GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-1.5-flash
